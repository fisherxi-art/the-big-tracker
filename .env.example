# Runtime: Node.js 22.5+ (uses built-in node:sqlite — no native addon build).
# On Node 22.5–22.12, `node:sqlite` requires --experimental-sqlite (npm scripts already pass it).

# Get a key at https://openrouter.ai/keys — never commit real keys.
OPENROUTER_API_KEY=
# Text (parse, classify) — fast model
OPENROUTER_MODEL=minimax/minimax-m2.1
# Pasted screenshots / image OCR — vision-capable id on OpenRouter (openrouter.ai/models → image)
OPENROUTER_VISION_MODEL=deepseek/deepseek-v3.2

# Web search plugin: off by default. Set to 1 to enable (extra OpenRouter usage).
# OPENROUTER_WEB_SEARCH=1
# OPENROUTER_WEB_MAX_RESULTS=5

# Server port (API + static in production). Render sets PORT automatically.
PORT=3000

# App data directory (created on first run)
DATA_DIR=./data

# SQLite database file. Default: {DATA_DIR}/app.db
# On Render with a persistent disk, use the mount path, e.g.:
# DATABASE_PATH=/var/data/app.db
DATABASE_PATH=

# Excel import (npm run import-excel). Defaults: {DATA_DIR}/research.xlsx and meetings.xlsx
# EXCEL_RESEARCH_PATH=./data/research.xlsx
# EXCEL_MEETINGS_PATH=./data/meetings.xlsx

# Optional: public site URL for OpenRouter referrer header
PUBLIC_URL=
